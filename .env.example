# Copy to .env for local development (.env is gitignored).

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite if unset. In production this is a Neon Postgres URL.
DATABASE_URL=sqlite+aiosqlite:///./data/resume.db

# ── Local auth shim ───────────────────────────────────────────────────────────
# Skips Google sign-in and impersonates this user. LOCAL DEV ONLY; never set in
# production (it bypasses auth).
DEV_USER_EMAIL=dev@example.com

# ── Auth (production) ─────────────────────────────────────────────────────────
# The app signs its own session cookie and signs users in with Google OAuth.
# APP_BASE_URL         Public origin. Builds the OAuth redirect URI and decides
#                      whether cookies get the Secure flag (https only).
# SESSION_SECRET       Random 32+ byte string signing the session cookie (REQUIRED
#                      in prod). Generate: openssl rand -base64 48
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET  From a Google OAuth 2.0 Web client whose
#                      authorized redirect URI is <APP_BASE_URL>/api/auth/google/callback
APP_BASE_URL=http://localhost:8080
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Signup / resource guardrails (production) ─────────────────────────────────
# All optional; unset = unlimited / off.
# MAX_USERS            Cap on distinct accounts; signups past it get a clean 403.
# MAX_VERSIONS_PER_USER  Per-user stored-version cap; commits rejected at the cap.
# COMPILE_RATE_PER_MIN / CHAT_RATE_PER_MIN  Per-user request budgets (default 30).
MAX_USERS=
MAX_VERSIONS_PER_USER=

# ── AI tailoring ──────────────────────────────────────────────────────────────
# Bring-your-own-credential: each user pastes a Claude API key (sk-ant-api…, bills
# API credits) or a Claude Code OAuth token (sk-ant-oat… from `claude setup-token`,
# bills their Claude subscription) in the in-app Settings screen — never here.
# Users without a key use the built-in copy-paste assistant.
