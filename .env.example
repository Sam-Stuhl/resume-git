# Copy to .env for local development (.env is gitignored).

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite if unset. In production this is a Neon Postgres URL.
DATABASE_URL=sqlite+aiosqlite:///./data/resume.db

# ── Local auth shim ───────────────────────────────────────────────────────────
# Outside Cloudflare Access there are no identity headers; impersonate a user.
DEV_USER_EMAIL=dev@example.com

# ── Cloudflare Access (production only) ───────────────────────────────────────
# When both are set, the app verifies the Access JWT. Leave blank locally.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ── Open self-serve signup guardrails (production) ────────────────────────────
# With an open Access policy (any Google account), these keep the app safe. All
# optional; the defaults below mean "unlimited / off" for local dev.
#
# REQUIRE_ACCESS_JWT   Fail closed: reject any request without a verifiable Access
#                      token, and ignore DEV_USER_EMAIL. Set to 1 in any public
#                      deployment (requires CF_ACCESS_* above to be set).
# MAX_USERS            Cap on distinct accounts; new signups past it get a clean
#                      403. 0 = unlimited.
# MAX_VERSIONS_PER_USER  Per-user stored-version cap; at the cap, new commits are
#                        rejected (history is never auto-deleted). 0 = unlimited.
# COMPILE_RATE_PER_MIN / CHAT_RATE_PER_MIN  Per-user request budgets (default 30).
REQUIRE_ACCESS_JWT=
MAX_USERS=
MAX_VERSIONS_PER_USER=

# ── AI tailoring ──────────────────────────────────────────────────────────────
# Bring-your-own-credential: each user pastes a Claude API key (sk-ant-api…, bills
# API credits) or a Claude Code OAuth token (sk-ant-oat… from `claude setup-token`,
# bills their Claude subscription) in the in-app Settings screen — never here.
# Users without a key use the built-in copy-paste assistant.
