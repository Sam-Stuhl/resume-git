# Copy to .env for local development (.env is gitignored).

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite if unset. In production this is a Neon Postgres URL.
DATABASE_URL=sqlite+aiosqlite:///./data/resume.db

# ── Local auth shim ───────────────────────────────────────────────────────────
# Outside Cloudflare Access there are no identity headers; impersonate a user.
DEV_USER_EMAIL=dev@example.com

# ── Cloudflare Access (production only) ───────────────────────────────────────
# When both are set, the app verifies the Access JWT. Leave blank locally.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ── AI tailoring ──────────────────────────────────────────────────────────────
# The Claude API key is stored per-user via the in-app Settings screen, not here.
